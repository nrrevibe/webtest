  "GSAP": {
    "category": "JavaScript libraries",
    "scripts": ["gsap.min.js", "TweenMax"],
    "globals": ["gsap", "TweenMax"]
  },
  "Moment.js": {
    "category": "JavaScript libraries",
    "scripts": ["moment.js", "moment.min.js"]
  },
  "Font Awesome": {
    "category": "Font scripts",
    "html": ["font-awesome", "fa-solid", "fa-brands"]
  },
