{
  "WordPress": {
    "category": "CMS",
    "html": ["wp-content", "wp-includes", "<meta name=\"generator\" content=\"WordPress"],
    "headers": { "x-pingback": "" },
    "scripts": ["wp-emoji-release"]
  },
  "WooCommerce": {
    "category": "Ecommerce",
    "html": ["woocommerce", "class=\"woocommerce"],
    "scripts": ["woocommerce"]
  },
  "Elementor": {
    "category": "Page builder",
    "html": ["elementor", "data-elementor-type"],
    "scripts": ["elementor"]
  },
  "Slider Revolution": {
    "category": "Widgets",
    "html": ["rs-plugin", "rev_slider"],
    "scripts": ["jquery.themepunch.revolution.min.js", "rbtools.min.js", "rs6.min.js"]
  },
  "Shopify": {
    "category": "Ecommerce",
    "html": ["cdn.shopify.com", "<meta name=\"generator\" content=\"Shopify"],
    "scripts": ["shopify"],
    "globals": ["Shopify"]
  },
  "React": {
    "category": "JavaScript frameworks",
    "html": ["data-reactroot"],
    "scripts": ["react.production.min.js", "react-dom.production.min.js"],
    "globals": ["__REACT_DEVTOOLS_GLOBAL_HOOK__"]
  },
  "Next.js": {
    "category": "JavaScript frameworks",
    "html": ["__next"],
    "globals": ["__NEXT_DATA__"]
  },
